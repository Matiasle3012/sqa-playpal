# ==============================================================================
# PlayPal Project Root .gitignore
# ==============================================================================

# System Files
.DS_Store
Thumbs.db
Desktop.ini

# IDEs and Text Editors
.idea/
.vscode/
*.iml
*.iws
*.ipr
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.classpath
.project
.settings/
.springBeans
.sts4-cache
.factorypath
.apt_generated
.claude/

# Diagnostic/Log files
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Frontend (Node.js & React/Vite)
node_modules/
dist/
dist-ssr/
*.local
.env
.env.development.local
.env.test.local
.env.production.local

# Backend (Java & Spring Boot)
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
build/
!**/src/main/**/build/
!**/src/test/**/build/
.gradle/
.jdk/
bin/

# Specific project rules
/backend-spring-boot/playpal/images/
/backend-spring-boot/playpal/src/main/resources/application.properties
